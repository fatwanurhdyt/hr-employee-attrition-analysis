                    <run bold='true' fontcolor='#000000' fontname='Helvetica' fontsize='11'>Key Insight</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Helvetica' fontsize='11'>Attrition is concentrated in specific employee segments, especially employees with overtime, sales roles, frequent travel, low income, low job involvement, and short tenure. Retention strategies should prioritize workload control, early-tenure support, and targeted incentives for high-risk roles.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='10' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#ffffff' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
                <format attr='background-color' value='#f9ece0' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{700CD958-BE9E-4D85-8E2A-BADAEB5F68A6}' />
