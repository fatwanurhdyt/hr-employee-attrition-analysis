                  <zone forceUpdate='true' h='26439' id='27' type-v2='text' w='33286' x='34070' y='72561'>
                    <formatted-text>
                      <run bold='true' fontcolor='#000000' fontname='Helvetica' fontsize='11'>Quick Read</run>
                      <run>Æ&#10;&#10;</run>
                      <run fontcolor='#ff8559' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Overtime</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'> — 3× risk vs. no overtime</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#ff8559' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Sales Rep</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'> — highest role attrition (39,8%)</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#ff8559' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Low income</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'> — nearly 29% attrition</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#ff8559' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Early tenure</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'> — 34.9% in first 1 year</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#ecb09b' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#ecb09b' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Frequent travel</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'> — 24.9% vs. 8% non-travel</run>
                      <run>Æ&#10;</run>
                      <run fontcolor='#ecb09b' fontname='Helvetica' fontsize='15'>●</run>
                      <run fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
                      <run bold='true' fontcolor='#141413' fontname='Helvetica' fontsize='11'>Low involvement</run>
                      <run bold='true' fontcolor='#3d3d3a' fontname='Helvetica' fontsize='11'>Æ </run>
